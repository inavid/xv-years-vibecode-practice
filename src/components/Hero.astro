---
---

<section
	class="relative h-[100dvh] min-h-screen w-full flex items-center justify-center overflow-hidden px-4 sm:px-6 lg:px-8"
>
	<div class="absolute inset-0 bg-black/40 z-10 w-full h-full"></div>
	<div class="absolute top-0 left-1/4 w-96 h-96 bg-[#C5A880]/10 rounded-full blur-3xl -translate-y-1/2"></div>
	<div class="absolute bottom-0 right-1/4 w-96 h-96 bg-[#C5A880]/8 rounded-full blur-3xl translate-y-1/3"></div>

	<div class="relative z-20 text-center text-white flex flex-col items-center justify-center px-4">
		<p
			class="mb-6 text-[1.9rem] md:text-[3rem] leading-none text-white/85"
			style="font-family: 'Segoe Script', 'Snell Roundhand', cursive; font-weight: 600; letter-spacing: 0.06em;"
		>
			Mis Quince Años
		</p>

		<h1
			class="text-white leading-none drop-shadow-[0_8px_24px_rgba(0,0,0,0.85)]"
			style="font-family: 'Brush Script MT', 'Segoe Script', 'Snell Roundhand', cursive; font-size: clamp(4.25rem, 13vw, 8rem); font-weight: 500;"
		>
			Nicole
		</h1>

		<div class="w-20 h-px bg-[#C5A880]/70 my-6"></div>

		<p
			class="font-playfair italic text-white/85 leading-tight"
			style="font-size: clamp(1.15rem, 3vw, 1.7rem);"
		>
			25 . Octubre . 2026
		</p>
	</div>

	<div class="absolute bottom-8 z-20 flex flex-col items-center animate-bounce">
		<span class="text-white/80 text-xs tracking-widest uppercase mb-2">
			Descubre
		</span>
		<svg
			xmlns="http://www.w3.org/2000/svg"
			fill="none"
			viewBox="0 0 24 24"
			stroke-width="1.5"
			stroke="currentColor"
			class="w-5 h-5 text-white/80"
		>
			<path
				stroke-linecap="round"
				stroke-linejoin="round"
				d="m19.5 8.25-7.5 7.5-7.5-7.5"></path>
		</svg>
	</div>
</section>
