---
// Events.astro
---

<section class="py-24 bg-[var(--color-bg-overlay-dark)] relative">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="font-playfair text-4xl md:text-5xl text-text-main mb-4">
                Ubicaciones
            </h2>
            <div class="w-24 h-[1px] bg-[#C5A880] mx-auto opacity-50"></div>
        </div>

        <div
            class="reveal-card slide-from-left grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-8 bg-white/10 backdrop-blur-md p-8 md:p-12 rounded-sm border border-white/20 shadow-xl"
        >
            <!-- Ceremonia -->
            <div class="flex flex-col items-center text-center group">
                <div
                    class="w-16 h-16 rounded-full bg-[#C5A880]/10 flex items-center justify-center mb-6 text-[#C5A880] transition-transform duration-500 group-hover:scale-110"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="1.2"
                        stroke="currentColor"
                        class="w-8 h-8"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z"
                        ></path>
                    </svg>
                </div>
                <h3 class="font-playfair text-3xl mb-2 text-text-main">
                    Ceremonia Religiosa
                </h3>
                <p
                    class="font-inter text-sm tracking-widest text-[#C5A880] uppercase mb-4"
                >
                    16:00 Hrs
                </p>
                <p class="font-inter text-text-main/70 mb-6 leading-relaxed">
                    Parroquia de San Miguel Arcángel<br />
                    Av. Principal #123, Centro
                </p>
                <a
                    href="#"
                    class="inline-block px-8 py-3 border border-[#C5A880] text-[#C5A880] hover:bg-[#C5A880] hover:text-white transition-colors duration-300 font-inter tracking-widest text-xs uppercase cursor-pointer"
                >
                    Ver Mapa
                </a>
            </div>

            <!-- Recepción -->
            <div class="flex flex-col items-center text-center group">
                <div
                    class="w-16 h-16 rounded-full bg-[#C5A880]/10 flex items-center justify-center mb-6 text-[#C5A880] transition-transform duration-500 group-hover:scale-110"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="1.2"
                        stroke="currentColor"
                        class="w-8 h-8"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"
                        ></path>
                    </svg>
                </div>
                <h3 class="font-playfair text-3xl mb-2 text-text-main">
                    Recepción
                </h3>
                <p
                    class="font-inter text-sm tracking-widest text-[#C5A880] uppercase mb-4"
                >
                    19:00 Hrs
                </p>
                <p class="font-inter text-text-main/70 mb-6 leading-relaxed">
                    Salón de Eventos "El Gran Jardín"<br />
                    Carretera Norte Km. 45
                </p>
                <a
                    href="#"
                    class="inline-block px-8 py-3 bg-[#C5A880] text-white hover:bg-[#a38a65] transition-colors duration-300 font-inter tracking-widest text-xs uppercase cursor-pointer"
                >
                    Ver Mapa
                </a>
            </div>
        </div>
    </div>
</section>
