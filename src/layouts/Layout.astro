---
import "../styles/global.css";
import colorsData from "../data/colors.json";

interface Props {
	title: string;
	description?: string;
	socialImage?: string;
	socialImageAlt?: string;
}

const {
	title,
	description = "Nicole celebra sus XV Años. Acompáñanos a celebrar un día inolvidable.",
	socialImage = "/social-share.png",
	socialImageAlt = "Portada de la invitación de Nicole para compartir en redes sociales",
} = Astro.props;
const { theme } = colorsData;
const siteUrl = Astro.site?.toString();
const socialImageUrl = siteUrl ? new URL(socialImage, siteUrl).toString() : socialImage;
const pageUrl = Astro.url?.href;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
			<meta property="og:type" content="website" />
			<meta property="og:url" content={pageUrl} />
			<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
			<meta property="og:image" content={socialImageUrl} />
			<meta property="og:image:alt" content={socialImageAlt} />
			<meta property="og:image:width" content="1200" />
			<meta property="og:image:height" content="630" />
			<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImageUrl} />
		<title>{title}</title>
	</head>
	<body
		class="antialiased overflow-x-hidden min-h-screen"
		style={`--color-primary: ${theme.primary}; --color-secondary: ${theme.secondary}; --color-text-main: ${theme.textMain}; --color-bg-overlay-light: ${theme.bgOverlayLight}; --color-bg-overlay-dark: ${theme.bgOverlayDark};`}
	>
		<!-- Fixed background workaround for iOS Safari (bg-fixed is broken on mobile) -->
		<div
			class="fixed inset-0 -z-10 bg-cover bg-center"
			style="background-image: url('/background_nicole_2.jpg');"
		></div>

		<main class="max-w-[100vw] overflow-hidden">
			<slot />
		</main>

		<!-- Scroll-reveal global styles -->
		<style is:global>
			.reveal-card {
				opacity: 0;
				transition:
					opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
					transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
				will-change: opacity, transform;
			}
			.slide-from-right {
				transform: translateX(80px);
			}
			.slide-from-left {
				transform: translateX(-80px);
			}
			.reveal-card.is-visible {
				opacity: 1;
				transform: translateX(0);
			}
		</style>

		<!-- Scroll-reveal IntersectionObserver -->
		<script>
			const cards = document.querySelectorAll('.reveal-card');
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-visible');
						} else {
							entry.target.classList.remove('is-visible');
						}
					});
				},
				{ threshold: 0.15 }
			);
			cards.forEach((card) => observer.observe(card));
		</script>
	</body>
</html>
